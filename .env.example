# Free-tier engine. Optional: set GROQ_API_KEY for faster/stronger output.
# Without it, the app uses a keyless free LLM (Pollinations). Get a Groq key
# (no credit card) at https://console.groq.com
GROQ_API_KEY=
# Optional overrides:
# GROQ_MODEL=llama-3.3-70b-versatile
# POLLINATIONS_MODEL=openai-fast
# GENERATE_TIMEOUT_MS=22000

# WordPress publishing (blog half). Set all three to enable "Publish to
# WordPress (draft)". Use an Application Password (Users -> Profile -> Application
# Passwords on any WordPress site). Without these, publishing returns a clear
# "not configured" message.
WP_URL=
WP_USER=
WP_APP_PASSWORD=
